<?xml version="1.0" encoding="utf-8"?>
<!-- Network Security Configuration for Movino -->
<!-- Allow cleartext (HTTP) for Stremio addon image compatibility -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
